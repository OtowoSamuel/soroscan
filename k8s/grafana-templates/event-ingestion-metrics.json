{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Ingestion incidents",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "enable": true,
        "expr": "increase(django_db_errors_total{type=\"ingest\"}[5m]) > 0",
        "iconColor": "rgba(255, 170, 0, 1)",
        "titleFormat": "Ingestion error burst",
        "textFormat": "Database ingest errors increased"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 11,
      "title": "Events Indexed / min",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(celery_tasks_total{name=~\".*ingest.*\",state=\"SUCCESS\",job=~\"$job\"}[1m])) * 60",
          "legendFormat": "indexed"
        }
      ]
    },
    {
      "id": 12,
      "title": "Ingestion Failures / min",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(celery_tasks_total{name=~\".*ingest.*\",state=\"FAILURE\",job=~\"$job\"}[1m])) * 60",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "id": 13,
      "title": "Task Runtime p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(celery_task_runtime_seconds_bucket{name=~\".*ingest.*\",instance=~\"$instance\"}[5m])) by (le, name))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 14,
      "title": "Deduplication and DB Errors",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(django_db_errors_total{job=~\"$job\"}[5m])) by (type)",
          "legendFormat": "db-{{type}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["soroscan", "ingestion", "events"],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(celery_tasks_total, job)",
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(celery_tasks_total{job=~\"$job\"}, instance)",
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "SoroScan - Event Ingestion Metrics",
  "uid": "soroscan-ingestion-template",
  "version": 1
}